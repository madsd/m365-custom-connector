# Microsoft Entra (required when AUTH_REQUIRED=true)
ENTRA_TENANT_ID=
# Application ID URI generated by the Teams Developer Portal SSO registration,
# e.g. api://<your-app-fqdn>/<client-id>. Comma-separated values allowed.
ENTRA_AUDIENCE=
# Defaults to Microsoft's enterprise token store client ID.
ENTRA_ALLOWED_CLIENT_IDS=ab3be6b7-f5df-413d-ac2d-abf1e3fd9c0b
# Set to false only for local testing or the first deploy.
AUTH_REQUIRED=true

# PubMed / NCBI (all optional)
NCBI_API_KEY=
NCBI_EMAIL=
NCBI_TOOL=m365-pubmed-connector

# Hosting
PORT=8000
MCP_PATH=/mcp
